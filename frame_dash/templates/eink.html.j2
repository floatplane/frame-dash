<!DOCTYPE html>
<html lang="en" data-theme="eink">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width={{ config.eink_width }}, height={{ config.eink_height }}">
  <style>
    {# Inline the CSS so Playwright can render without serving static files #}
    {% include "static/eink.css" %}
  </style>
</head>
{# ---- Monochrome weather icons (crisp on grayscale e-ink) ---- #}
{# Outline weather icons; shared stroke/no-fill styling lives in .wx-icon CSS #}
{%- macro wicon(cond) -%}
{%- set c = cond | lower -%}
{%- if c in ["sunny", "clear"] -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><circle cx="12" cy="12" r="3.8"/><line x1="12" y1="1.8" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22.2"/><line x1="1.8" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22.2" y2="12"/><line x1="4.6" y1="4.6" x2="6.2" y2="6.2"/><line x1="17.8" y1="17.8" x2="19.4" y2="19.4"/><line x1="19.4" y1="4.6" x2="17.8" y2="6.2"/><line x1="6.2" y1="17.8" x2="4.6" y2="19.4"/></svg>
{%- elif c == "clear-night" -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3 6.6 6.6 0 0 0 21 12.8z"/></svg>
{%- elif c == "partlycloudy" -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><circle cx="8" cy="7.5" r="2.8"/><line x1="8" y1="2" x2="8" y2="3.2"/><line x1="2.8" y1="7.5" x2="4" y2="7.5"/><line x1="4.1" y1="3.6" x2="5" y2="4.5"/><line x1="11.9" y1="3.6" x2="11" y2="4.5"/><path d="M8 20a4 4 0 0 1 0-8 5.3 5.3 0 0 1 10.2-1.4A3.6 3.6 0 0 1 18 20z" fill="#fff"/></svg>
{%- elif c == "cloudy" -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M6.5 18a4.5 4.5 0 0 1 0-9 6 6 0 0 1 11.5-1.6A4 4 0 0 1 17.5 18z"/></svg>
{%- elif c in ["rainy", "pouring", "snowy-rainy"] -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M6.5 14.5a4.3 4.3 0 0 1 0-8.6 5.7 5.7 0 0 1 11-1.5A3.8 3.8 0 0 1 17 14.5z"/><line x1="8.5" y1="17.5" x2="7.4" y2="20.5"/><line x1="12" y1="17.5" x2="10.9" y2="20.5"/><line x1="15.5" y1="17.5" x2="14.4" y2="20.5"/></svg>
{%- elif c in ["snowy", "hail"] -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M6.5 14.5a4.3 4.3 0 0 1 0-8.6 5.7 5.7 0 0 1 11-1.5A3.8 3.8 0 0 1 17 14.5z"/><g fill="#000" stroke="none"><circle cx="8.5" cy="18.5" r="1"/><circle cx="12" cy="18.5" r="1"/><circle cx="15.5" cy="18.5" r="1"/></g></svg>
{%- elif c in ["lightning", "lightning-rainy"] -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M6.5 13.5a4.3 4.3 0 0 1 0-8.6 5.7 5.7 0 0 1 11-1.5A3.8 3.8 0 0 1 17 13.5z"/><path d="M13 14l-3 5h2.4l-1 4 4.1-5.4h-2.6z"/></svg>
{%- elif c == "fog" -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><line x1="3" y1="7" x2="21" y2="7"/><line x1="5" y1="11" x2="19" y2="11"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="6" y1="19" x2="18" y2="19"/></svg>
{%- elif c in ["windy", "windy-variant"] -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M3 8h10a2.5 2.5 0 1 0-2.5-2.5"/><path d="M3 12h14a2.6 2.6 0 1 1-2.6 2.6"/><path d="M3 16h7a2.2 2.2 0 1 1-2.2 2.2"/></svg>
{%- else -%}
<svg viewBox="0 -2 24 28" class="wx-icon"><path d="M6.5 18a4.5 4.5 0 0 1 0-9 6 6 0 0 1 11.5-1.6A4 4 0 0 1 17.5 18z"/></svg>
{%- endif -%}
{%- endmacro -%}
{# Energy source icon: solar / battery / grid #}
{%- macro sourceicon(src) -%}
{%- if src == "solar" -%}
<svg viewBox="0 -2 24 28" class="energy-icon"><circle cx="12" cy="12" r="3.6"/><line x1="12" y1="2.2" x2="12" y2="4.4"/><line x1="12" y1="19.6" x2="12" y2="21.8"/><line x1="2.2" y1="12" x2="4.4" y2="12"/><line x1="19.6" y1="12" x2="21.8" y2="12"/><line x1="5" y1="5" x2="6.5" y2="6.5"/><line x1="17.5" y1="17.5" x2="19" y2="19"/><line x1="19" y1="5" x2="17.5" y2="6.5"/><line x1="6.5" y1="17.5" x2="5" y2="19"/></svg>
{%- elif src == "battery" -%}
<svg viewBox="0 -2 24 28" class="energy-icon"><rect x="2.5" y="8.5" width="15" height="9" rx="1.8"/><line x1="19.4" y1="11.3" x2="19.4" y2="14.7"/><line x1="6" y1="11" x2="6" y2="15"/><line x1="9" y1="11" x2="9" y2="15"/><line x1="12" y1="11" x2="12" y2="15"/></svg>
{%- else -%}
<svg viewBox="0 -2 24 28" class="energy-icon"><path d="M12 2.5 L6.5 21.5 M12 2.5 L17.5 21.5 M9.6 6.5 H14.4 M8.4 12 H15.6 M7.4 16.5 H16.6"/></svg>
{%- endif -%}
{%- endmacro -%}
<body>
  <div class="eink">

    {# ---- Header: date + hourly forecast ---- #}
    <div class="eink__header">
      <div class="eink__header-left">
        <div class="eink__date">{{ now.strftime("%A, %B %-d") }}</div>
        {% if data.sunrise and data.sunset %}
        <div class="eink__sun">
          {# Show only the next sun event: sunset during the day, sunrise overnight #}
          {% if data.sunrise < data.sunset %}
          Sunrise {{ data.sunrise.strftime("%-I:%M %p").lower() }}
          {% else %}
          Sunset {{ data.sunset.strftime("%-I:%M %p").lower() }}
          {% endif %}
        </div>
        {% endif %}
      </div>
      {% if data.weather and data.weather.hourly %}
      <div class="wx-hours">
        {% for h in data.weather.hourly %}
        <div class="wx-hour">
          <div class="wx-hour__time">{{ h.hour_label }}</div>
          <div class="wx-hour__icon">{{ wicon(h.condition) }}</div>
          <div class="wx-hour__temp">{{ h.temperature | temp_fmt(data.weather.temperature_unit) }}</div>
          <div class="wx-hour__precip">{% if h.precip_probability %}{{ h.precip_probability | int }}%{% endif %}</div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    {# ---- Calendar (Today + Tomorrow) ---- #}
    <div class="eink__calendar">
      <div class="eink__section-title">Today</div>
      {% if data.events_today %}
      <ul class="eink__events">
        {% for event in data.events_today %}
        <li class="eink__event">
          <span class="eink__event-time">{{ event.time_str }}</span>
          <span class="eink__event-summary">{{ event.summary }}</span>
          {% if config.calendars | length > 1 %}
          <span class="eink__event-calendar">{{ event.calendar_name }}</span>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <div class="eink__empty">Nothing scheduled</div>
      {% endif %}

      {% if data.events_tomorrow %}
      <div class="eink__section-title eink__section-title--second">Tomorrow</div>
      <ul class="eink__events">
        {% for event in data.events_tomorrow %}
        <li class="eink__event">
          <span class="eink__event-time">{{ event.time_str }}</span>
          <span class="eink__event-summary">{{ event.summary }}</span>
          {% if config.calendars | length > 1 %}
          <span class="eink__event-calendar">{{ event.calendar_name }}</span>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>

    {# ---- Status (attention + climate) ---- #}
    <div class="eink__status">
      {% if data.attention_items %}
      <ul class="eink__status-items">
        {% for item in data.attention_items %}
        <li class="eink__status-item">
          {% if item.domain == "sensor" %}
            {{ item.state }}
          {% elif item.domain == "lock" and item.state == "unlocked" %}
            {{ item.friendly_name }} unlocked
          {% elif item.domain == "light" and item.state == "on" %}
            {{ item.friendly_name }} on
          {% elif item.domain == "binary_sensor" %}
            {{ item.friendly_name }} open
          {% else %}
            {{ item.friendly_name }}: {{ item.state }}
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if data.climate_states %}
      <ul class="eink__status-items" style="margin-top: 24px;">
        {% for item in data.climate_states %}
        <li class="eink__status-item eink__status-item--climate">
          {% if item.domain == "climate" %}
            {{ item.friendly_name }}:
            {{ item.attributes.get("current_temperature", item.state) }}°
            → {{ item.attributes.get("temperature", "?") }}°
          {% elif item.domain == "sensor" %}
            {{ item.friendly_name }}: {{ item.state }}{{ item.attributes.get("unit_of_measurement", "") }}
          {% else %}
            {{ item.friendly_name }}: {{ item.state }}
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>

    {# ---- Bottom strip: ambient stats + last updated ---- #}
    <div class="eink__footer">
      <div class="eink__stats">
        {% if data.vehicle %}
        <div class="eink__vehicle">
          <div class="eink__stat-label">{{ data.vehicle.name }}</div>
          <div class="eink__vehicle-row">
            {% if data.vehicle.charging %}
            <svg class="batt-bolt" viewBox="0 0 24 24"><path d="M14 1 L5 13 H11 L10 23 L19 11 H13 Z"/></svg>
            {% endif %}
            {% if data.vehicle.battery is not none %}
            <span class="batt">
              <span class="batt__fill" style="width: {{ data.vehicle.battery | round | int }}%"></span>
            </span>
            {% endif %}
            <span class="eink__vehicle-range">{% if data.vehicle.range is not none %}{{ data.vehicle.range | round | int }} {{ data.vehicle.range_unit }}{% else %}—{% endif %}</span>
          </div>
        </div>
        {% endif %}
        {% if data.energy %}
        <div class="eink__energy">
          <div class="eink__stat-label">Energy</div>
          <div class="eink__energy-row">
            {{ sourceicon(data.energy.source) }}
            <span class="eink__energy-value">{% if data.energy.independence is not none %}{{ data.energy.independence | round | int }}% independent{% else %}—{% endif %}</span>
          </div>
        </div>
        {% endif %}
      </div>
      <div class="eink__updated">Updated {{ now.strftime("%-I:%M %p") }}</div>
    </div>

  </div>
</body>
</html>
